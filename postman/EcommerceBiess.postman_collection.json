            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{backend_base_url}}/products",
              "host": [
                "{{backend_base_url}}"
              ],
              "path": [
                "products"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create PayPhone Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Crear pedido devuelve 201 o error controlado', function () {",
                  "  pm.expect([201, 400, 502]).to.include(pm.response.code);",
                  "});",
                  "",
                  "let data = {};",
                  "try {",
                  "  data = pm.response.json();",
                  "} catch (error) {",
                  "  data = {};",
                  "}",
                  "",
                  "if (data.id) {",
                  "  pm.environment.set('order_id', data.id);",
                  "}",
                  "if (data.payphoneClientTransactionId) {",
                  "  pm.environment.set('payphone_client_transaction_id', data.payphoneClientTransactionId);",
                  "}",
                  "if (data.payphoneTransactionId) {",
                  "  pm.environment.set('payphone_transaction_id', data.payphoneTransactionId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customer_access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentMethod\": \"payphone\",\n  \"phoneNumber\": \"{{customer_phone}}\",\n  \"countryCode\": \"{{country_code}}\",\n  \"shippingAddress\": {\n    \"address\": \"Av. Principal 123\",\n    \"city\": \"Quito\",\n    \"note\": \"Prueba desde Postman\"\n  },\n  \"items\": [\n    {\n      \"productId\": \"{{product_id_1}}\",\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{backend_base_url}}/orders",
              "host": [
                "{{backend_base_url}}"
              ],
              "path": [
                "orders"
              ]
            }
          },
          "response": []
        },
