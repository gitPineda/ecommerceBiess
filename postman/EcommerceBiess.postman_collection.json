    {
      "name": "2. PayPhone Directo",
      "item": [
        {
          "name": "Users Check",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{payphone_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{payphone_base_url}}/Users/check/{{customer_phone}}/region/{{country_code}}",
              "host": [
                "{{payphone_base_url}}"
              ],
              "path": [
                "Users",
                "check",
                "{{customer_phone}}",
                "region",
                "{{country_code}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Sale Direct",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const now = new Date();",
                  "const pad = (value) => String(value).padStart(2, '0');",
                  "const timestamp = `${now.getFullYear()}${pad(now.getMonth() + 1)}${pad(now.getDate())}${pad(now.getHours())}${pad(now.getMinutes())}${pad(now.getSeconds())}`;",
                  "const suffix = Math.floor(Math.random() * 1000).toString().padStart(3, '0');",
                  "pm.environment.set('postman_client_transaction_id', `pm-${timestamp}-${suffix}`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let data = {};",
                  "try {",
                  "  data = pm.response.json();",
                  "} catch (error) {",
                  "  data = {};",
                  "}",
                  "",
                  "if (data.clientTransactionId) {",
                  "  pm.environment.set('payphone_client_transaction_id', data.clientTransactionId);",
                  "}",
                  "if (data.transactionId) {",
                  "  pm.environment.set('payphone_transaction_id', data.transactionId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{payphone_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{customer_phone}}\",\n  \"countryCode\": \"{{country_code}}\",\n  \"amount\": {{sale_amount}},\n  \"amountWithoutTax\": {{sale_amount_without_tax}},\n  \"amountWithTax\": {{sale_amount_with_tax}},\n  \"tax\": {{sale_tax}},\n  \"service\": 0,\n  \"tip\": 0,\n  \"storeId\": \"{{payphone_store_id}}\",\n  \"clientTransactionId\": \"{{postman_client_transaction_id}}\",\n  \"currency\": \"USD\",\n  \"reference\": \"Prueba Postman EcommerceBiess\"\n}"
            },
            "url": {
              "raw": "{{payphone_base_url}}/Sale",
              "host": [
                "{{payphone_base_url}}"
              ],
              "path": [
                "Sale"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Sale By Client Transaction Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{payphone_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{payphone_base_url}}/Sale/client/{{payphone_client_transaction_id}}",
              "host": [
                "{{payphone_base_url}}"
              ],
              "path": [
                "Sale",
                "client",
                "{{payphone_client_transaction_id}}"
              ]
            }
          },
          "response": []
        }
      ]
