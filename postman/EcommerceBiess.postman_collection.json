        {
          "name": "List Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Lista de productos responde 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "const items = data.items || [];",
                  "if (items[0]?.id) {",
                  "  pm.environment.set('product_id_1', items[0].id);",
                  "  pm.environment.set('product_name_1', items[0].name || '');",
                  "}",
                  "if (items[1]?.id) {",
                  "  pm.environment.set('product_id_2', items[1].id);",
                  "  pm.environment.set('product_name_2', items[1].name || '');",
                  "}"
                ],
                "type": "text/javascript"
